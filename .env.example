# === LLM / embedding (Ollama default) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_LLM=llama3.1:8b
OLLAMA_MODEL_EMBED=nomic-embed-text

# vLLM (OpenAI-compatible) — fill in to switch
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# VLLM_API_KEY=EMPTY

# === Vector store ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_default

# === Graph store (optional, for visualization) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# === Tracing (optional) ===
PHOENIX_ENABLED=false
PHOENIX_ENDPOINT=http://localhost:6006

# === Paths ===
DATA_DIR=./data
EXPERIMENTS_DIR=./experiments

# === Optional: external LLMs (for synth/eval cross-check only) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Ragas judge LLM ===
# Generation pipelines always use OLLAMA_MODEL_LLM. The judge that grades
# faithfulness / context precision etc. can be swapped to Anthropic or OpenAI
# when llama3.1:8b is too weak (Phase 1 demo: faithfulness=NaN was usually a
# judge timeout, not the generator). Empty model -> backend default.
RAGAS_JUDGE_BACKEND=ollama   # one of: ollama | anthropic | openai
RAGAS_JUDGE_MODEL=           # e.g. claude-haiku-4-5-20251001 / gpt-4o-mini
