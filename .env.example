# === LLM / embedding (Ollama default) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_LLM=llama3.1:8b
OLLAMA_MODEL_EMBED=nomic-embed-text

# vLLM (OpenAI-compatible) — fill in to switch
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# VLLM_API_KEY=EMPTY

# === Vector store ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_default

# === Graph store (optional, for visualization) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# === Tracing (optional) ===
PHOENIX_ENABLED=false
PHOENIX_ENDPOINT=http://localhost:6006

# === Paths ===
DATA_DIR=./data
EXPERIMENTS_DIR=./experiments

# === Optional: external LLMs (for synth/eval cross-check only) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
